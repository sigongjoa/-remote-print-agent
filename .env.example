# ── 공통 ──────────────────────────────────────────
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Local Dispatcher ──────────────────────────────
# rclone remote 이름:폴더 (예: gdrive:remote-print-agent)
DRIVE_FOLDER=remote-print-agent

# ── Academy Executor (학원 PC) ────────────────────
# Google Drive for Desktop 동기화 경로 (Windows 예: G:\내 드라이브)
DRIVE_SYNC_PATH=G:\내 드라이브

# 프린터 이름 (Windows 제어판 > 장치 및 프린터에서 확인)
PRINTER_NAME=HP LaserJet Pro MFP

# SumatraPDF 실행 파일 전체 경로
SUMATRA_PATH=C:\Program Files\SumatraPDF\SumatraPDF.exe

# 카카오톡 나에게 보내기 access_token
KAKAO_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion 폴링 간격 (초, 기본 60)
POLL_INTERVAL=60
